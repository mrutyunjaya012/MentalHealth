# MongoDB Atlas connection string
# Replace <username>, <password>, and <cluster> with your Atlas credentials
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/MentalHealth?retryWrites=true&w=majority

# Server
PORT=5001
NODE_ENV=development

# Comma-separated allowed frontend origins (Vite default shown)
CLIENT_URL=http://localhost:5173
